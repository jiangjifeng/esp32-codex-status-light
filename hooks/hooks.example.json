{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"__REPO_PATH__\\hooks\\codex_status_light_hook.ps1\" idle -SenderScript \"__REPO_PATH__\\codex_status_light.ps1\" -Port COM6",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"__REPO_PATH__\\hooks\\codex_status_light_hook.ps1\" idle -SenderScript \"__REPO_PATH__\\codex_status_light.ps1\" -Port COM6",
            "timeout": 5,
            "statusMessage": "Setting Codex status light to idle"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"__REPO_PATH__\\hooks\\codex_status_light_hook.ps1\" running -SenderScript \"__REPO_PATH__\\codex_status_light.ps1\" -Port COM6",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"__REPO_PATH__\\hooks\\codex_status_light_hook.ps1\" running -SenderScript \"__REPO_PATH__\\codex_status_light.ps1\" -Port COM6",
            "timeout": 5,
            "statusMessage": "Setting Codex status light to running"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"__REPO_PATH__\\hooks\\codex_status_light_hook.ps1\" permission -SenderScript \"__REPO_PATH__\\codex_status_light.ps1\" -Port COM6",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"__REPO_PATH__\\hooks\\codex_status_light_hook.ps1\" permission -SenderScript \"__REPO_PATH__\\codex_status_light.ps1\" -Port COM6",
            "timeout": 5,
            "statusMessage": "Setting Codex status light to permission"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"__REPO_PATH__\\hooks\\codex_status_light_hook.ps1\" running -SenderScript \"__REPO_PATH__\\codex_status_light.ps1\" -Port COM6",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"__REPO_PATH__\\hooks\\codex_status_light_hook.ps1\" running -SenderScript \"__REPO_PATH__\\codex_status_light.ps1\" -Port COM6",
            "timeout": 5,
            "statusMessage": "Setting Codex status light to running"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"__REPO_PATH__\\hooks\\codex_status_light_hook.ps1\" stop -SenderScript \"__REPO_PATH__\\codex_status_light.ps1\" -Port COM6",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"__REPO_PATH__\\hooks\\codex_status_light_hook.ps1\" stop -SenderScript \"__REPO_PATH__\\codex_status_light.ps1\" -Port COM6",
            "timeout": 5,
            "statusMessage": "Updating Codex status light after turn"
          }
        ]
      }
    ]
  }
}
